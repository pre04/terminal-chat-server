{
  "manifest_version": 3,
  "name": "Terminal Chat",
  "version": "1.1.0",
  "description": "Connect to a Terminal Chat Server from your browser toolbar",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Terminal Chat",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"]
}
